<h2 style="text-align:center; color:#2c3e50; font-family:Arial, sans-serif; margin-bottom:25px;">
  Course details of <%= @course.name %>
</h2>

<% if @course %>
  <div style="max-width:600px; margin:0 auto; background:#ffffff; padding:25px; border-radius:12px; box-shadow:0 6px 16px rgba(0,0,0,0.1); font-family:Arial, sans-serif;">
    
    <p style="margin:10px 0;"><strong style="color:#34495e;">Course ID:</strong> <span style="color:#2c3e50;"><%= @course.id %></span></p>
    <p style="margin:10px 0;"><strong style="color:#34495e;">Course Name:</strong> <span style="color:#2c3e50;"><%= @course.name %></span></p>
    <p style="margin:10px 0;"><strong style="color:#34495e;">Course Duration:</strong> <span style="color:#2c3e50;"><%= @course.duration %></span></p>
    
    <p style="margin:15px 0 8px 0; font-weight:bold; color:#34495e;">Subjects:</p>
    <ul style="list-style-type:disc; padding-left:20px; color:#2c3e50;">
      <% @course.subjects.split(",").each do |sub| %>
        <li style="margin-bottom:6px; transition: color 0.3s;" onmouseover="this.style.color='#3498db';" onmouseout="this.style.color='#2c3e50';"><%= sub.strip %></li>
      <% end %>
    </ul>
    
  </div>
<% else %>
  <p style="text-align:center; color:#95a5a6; font-style:italic;">No course found with this name.</p>
<% end %>

<% if current_user&.role=="student" %>
<div style="text-align:center; margin-top:20px;">
  <%= link_to "Back to Main Page", applications_path, style:"text-decoration:none; color:#3498db; font-weight:bold; font-size:1rem; transition: color 0.3s;", onmouseover:"this.style.color='#2980b9';", onmouseout:"this.style.color='#3498db';" %>
</div>
<% else %>
<div style="text-align:center; margin-top:20px;">
  <%= link_to "Back to Main Page", root_path, style:"text-decoration:none; color:#3498db; font-weight:bold; font-size:1rem; transition: color 0.3s;", onmouseover:"this.style.color='#2980b9';", onmouseout:"this.style.color='#3498db';" %>
</div>
<% end %>